# ─── Application ────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=MechMate

# ─── Database ───────────────────────────────────────────
# SQLite (dev)
DB_TYPE=sqlite
DB_PATH=./data/mechmate.db

# PostgreSQL (production) – uncomment for production
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=mechmate
# DB_PASSWORD=mechmate_secret
# DB_DATABASE=mechmate

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# ─── Firebase ───────────────────────────────────────────
FIREBASE_PROJECT_ID=mechmate-production
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Google Maps ────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Razorpay (payments) ────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Sentry ─────────────────────────────────────────────
SENTRY_DSN=

# ─── Rate Limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
